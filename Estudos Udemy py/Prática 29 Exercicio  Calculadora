import math
import time

# FUNÇÕES 
def soma(a , b):
    return a + b

def subtração(a , b):
    return a - b

def multiplicação(a , b):
    return a * b

def divisão(a , b):
    if b == 0:
        return "Erro! Não existe divisão de zero"
    return a / b    

def potenciação(a , b):
    return a ** b

def raiz_quadrada(a):
    if a < 0: 
        return "Erro! Não há raiz quadrada de números negativos"
    return math.sqrt(a)

